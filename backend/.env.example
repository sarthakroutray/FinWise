# FinWise backend environment example
APP_NAME=FinWise AI
DEBUG=true

# Local fallback DB
DB_URL=sqlite:///./finwise.db

# Neon Postgres for /documents metadata
NEON_DATABASE_URL=postgresql+pg8000://<user>:<password>@<host>/<db>?sslmode=require

# Parser mode: auto | opendataloader | native
PDF_PARSER=auto

# Firebase Admin SDK (backend token verification)
# Use ONE of the following:
FIREBASE_CREDENTIALS_PATH=C:/path/to/firebase-service-account.json
FIREBASE_CREDENTIALS_JSON=
FIREBASE_PROJECT_ID=<firebase-project-id>

# Comma-separated frontend origins allowed by CORS
# Example: http://localhost:3000,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# RLM provider: gemini | openrouter
RLM_PROVIDER=openrouter

# Shared model defaults (override per request from UI if needed)
RLM_MODEL=openrouter/auto
RLM_RECURSIVE_MODEL=openrouter/auto

# Gemini (AI Studio)
GEMINI_API_KEY=<your-ai-studio-key>
GEMINI_PRO_API_KEY=
GEMINI_FLASH_API_KEY_1=
GEMINI_FLASH_API_KEY_2=

# OpenRouter
OPENROUTER_API_KEY=<your-openrouter-key>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
# Comma-separated model allowlist used for free fallback routing.
OPENROUTER_FREE_MODELS=meta-llama/llama-3.3-8b-instruct:free,google/gemma-3-27b-it:free,qwen/qwen-2.5-7b-instruct:free
